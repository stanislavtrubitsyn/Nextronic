{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "entryFile": "main",
  "compilerOptions": {
    "deleteOutDir": true,
    "manualRestart": true,
    "assets": ["**/*.entity{.ts,.js}"],
    "paths": {
      "@/*": ["src/*"]
    }
  }
}
